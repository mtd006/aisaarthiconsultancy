<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1">
<title>Login - AI Tukaram Consultancy</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;font-family:Arial,sans-serif;}
  body{min-height:100vh;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,#6366f1,#8b5cf6);}
  .card{background:#fff;padding:40px;border-radius:12px;width:100%;max-width:380px;box-shadow:0 10px 30px rgba(0,0,0,0.2);}
  h1{font-size:1.4rem;margin-bottom:6px;color:#1e293b;}
  p.sub{color:#64748b;font-size:0.85rem;margin-bottom:20px;}
  label{font-size:0.8rem;color:#334155;display:block;margin:12px 0 4px;}
  input{width:100%;padding:10px;border:1px solid #cbd5e1;border-radius:6px;font-size:0.95rem;}
  button{width:100%;margin-top:20px;padding:11px;background:#6366f1;color:#fff;border:none;border-radius:6px;font-size:0.95rem;cursor:pointer;}
  button:hover{background:#4f46e5;}
  .alert{margin-top:14px;padding:10px;border-radius:6px;font-size:0.85rem;display:none;}
  .alert.error{background:#fee2e2;color:#991b1b;display:block;}
  .alert.success{background:#dcfce7;color:#166534;display:block;}
  .links{margin-top:16px;text-align:center;font-size:0.85rem;}
  .links a{color:#6366f1;text-decoration:none;}
</style>
</head>
<body>
<div class="card">
  <h1>Welcome Back</h1>
  <p class="sub">Sign in to AI Tukaram Consultancy</p>
  <div id="alert" class="alert"></div>
  <form id="loginForm">
    <label>User ID</label>
    <input type="text" id="userId" required>
    <label>Password</label>
    <input type="password" id="password" required>
    <label>Admin PIN (leave blank if you're a client)</label>
    <input type="text" id="pin">
    <button type="submit">Sign In</button>
  </form>
  <div class="links">
    <a href="/register">Create a corporate account</a> &nbsp;|&nbsp;
    <a href="#" onclick="forgot()">Forgot password?</a> &nbsp;|&nbsp;
    <a href="/">Home</a>
  </div>
</div>
<script>
  document.getElementById('loginForm').addEventListener('submit', async function(e){
    e.preventDefault();
    const alertBox = document.getElementById('alert');
    alertBox.style.display = 'none';
    try {
      const res = await fetch('/api/login', {
        method: 'POST', headers: {'Content-Type':'application/json'},
        body: JSON.stringify({ userId: userId.value.trim(), password: password.value, pin: pin.value.trim() })
      });
      const data = await res.json();
      if (data.success) { window.location.href = data.redirect; }
      else { alertBox.className='alert error'; alertBox.textContent = data.message; }
    } catch(err){ alertBox.className='alert error'; alertBox.textContent='Network error'; }
  });
  async function forgot(){
    const userId = prompt('Enter your User ID to receive reset instructions:');
    if (!userId) return;
    const res = await fetch('/api/forgot-password', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ userId }) });
    const data = await res.json();
    alert(data.message);
  }
</script>
</body>
</html>
