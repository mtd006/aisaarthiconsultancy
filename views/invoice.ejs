<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Invoice <%= invoice.invoiceNumber %></title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;font-family:'Helvetica',Arial,sans-serif;}
  body{padding:30px;color:#1e293b;background:#fff;}
  .invoice{max-width:800px;margin:auto;border:1px solid #e2e8f0;}
  .head{background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;padding:30px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
  .biz h1{font-size:1.5rem;margin-bottom:4px;}
  .biz p{font-size:0.85rem;opacity:0.9;}
  .inv-meta{text-align:right;}
  .inv-meta h2{font-size:1.8rem;letter-spacing:2px;margin-bottom:8px;}
  .body-section{padding:30px;}
  .parties{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-bottom:30px;}
  .party{padding:20px;background:#f8fafc;border-radius:8px;border-left:4px solid #6366f1;}
  .party h3{font-size:0.75rem;text-transform:uppercase;color:#6366f1;margin-bottom:10px;letter-spacing:1px;}
  table{width:100%;border-collapse:collapse;margin-bottom:24px;}
  th{background:#1e293b;color:#fff;padding:12px;text-align:left;font-size:0.85rem;text-transform:uppercase;}
  td{padding:14px 12px;border-bottom:1px solid #e2e8f0;font-size:0.9rem;}
  .totals{margin-left:auto;width:300px;}
  .total-row{display:flex;justify-content:space-between;padding:8px 0;font-size:0.92rem;}
  .total-row.grand{background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;padding:14px;border-radius:8px;margin-top:10px;font-size:1.1rem;font-weight:700;}
  .status-badge{display:inline-block;padding:6px 14px;border-radius:20px;font-size:0.8rem;font-weight:700;text-transform:uppercase;}
  .paid{background:#10b981;color:#fff;} .pending{background:#f59e0b;color:#fff;}
  .product-stamp{text-align:center;padding:16px;background:#0f172a;color:#94a3b8;font-size:0.8rem;}
  @media print { body{padding:0;} .invoice{border:none;} }
</style>
</head>
<body>
<div class="invoice">
  <div class="head">
    <div class="biz">
      <h1><%= business.businessName || 'AI Tukaram Consultancy' %></h1>
      <p><%= business.tagline || '' %></p>
      <p style="margin-top:8px;font-size:0.78rem;"><%= business.address || '' %></p>
    </div>
    <div class="inv-meta">
      <h2>INVOICE</h2>
      <p><strong>#<%= invoice.invoiceNumber %></strong></p>
      <p><%= new Date(invoice.invoiceDate).toDateString() %></p>
      <p style="margin-top:6px;"><span class="status-badge <%= invoice.paymentStatus === 'Paid' ? 'paid' : 'pending' %>"><%= invoice.paymentStatus %></span></p>
    </div>
  </div>
  <div class="body-section">
    <div class="parties">
      <div class="party">
        <h3>FROM</h3>
        <p><strong><%= business.businessName || '' %></strong></p>
        <p><%= business.address || '' %></p>
        <p>ðŸ“ž <%= business.contactNumber || '' %></p>
        <p>âœ‰ï¸ <%= business.email || '' %></p>
        <% if (business.gstNumber) { %><p>GST: <%= business.gstNumber %></p><% } %>
      </div>
      <div class="party">
        <h3>BILL TO</h3>
        <p><strong><%= invoice.clientName || '' %></strong></p>
        <p>Client ID: <%= invoice.clientId || '' %></p>
        <p>âœ‰ï¸ <%= invoice.email || '' %></p>
        <p>ðŸ“ž <%= invoice.phone || '' %></p>
      </div>
    </div>
    <table>
      <thead><tr><th>#</th><th>Service Description</th><th>Type</th><th style="text-align:right;">Amount</th></tr></thead>
      <tbody>
        <tr>
          <td>1</td>
          <td><strong><%= invoice.serviceName || '' %></strong></td>
          <td><%= invoice.purchaseType || 'One-time' %></td>
          <td style="text-align:right;"><%= business.currencySymbol || 'â‚¹' %> <%= invoice.amount || 0 %></td>
        </tr>
      </tbody>
    </table>
    <div class="totals">
      <div class="total-row"><span>Subtotal</span><span><%= business.currencySymbol || 'â‚¹' %> <%= invoice.amount || 0 %></span></div>
      <% if (invoice.discountAmount > 0) { %>
      <div class="total-row" style="color:#10b981;"><span>Discount</span><span>- <%= business.currencySymbol || 'â‚¹' %> <%= invoice.discountAmount %></span></div>
      <% } %>
      <% if (invoice.taxAmount > 0) { %>
      <div class="total-row"><span>Tax</span><span><%= business.currencySymbol || 'â‚¹' %> <%= invoice.taxAmount %></span></div>
      <% } %>
      <div class="total-row grand"><span>TOTAL DUE</span><span><%= business.currencySymbol || 'â‚¹' %> <%= invoice.finalAmount || invoice.amount || 0 %></span></div>
    </div>
  </div>
  <div class="product-stamp"><strong>A Product of Tukaram Consultancy</strong> &bull; <%= business.businessName || '' %></div>
</div>
<script>window.onload = () => { if (location.search.includes('print=1')) window.print(); };</script>
</body>
</html>
